# SONYA Production Environment — replace all CHANGE_ME values before deploy
# Copy to .env (never commit .env)

# App environment
APP_ENV=production

# Database (PostgreSQL only — no SQLite)
DATABASE_URL=CHANGE_ME

# S3 Storage (Timeweb Cloud S3 or any S3-compatible)
S3_BUCKET_NAME=CHANGE_ME
S3_ACCESS_KEY_ID=CHANGE_ME
S3_SECRET_ACCESS_KEY=CHANGE_ME
S3_ENDPOINT_URL=https://s3.timeweb.cloud
S3_REGION=ru-1

# Models bucket (can be same as S3_BUCKET_NAME)
MODELS_S3_BUCKET=CHANGE_ME

# Worker auth secret (use: openssl rand -hex 32)
WORKER_SECRET=CHANGE_ME

# AI APIs
GEMINI_API_KEY=CHANGE_ME
OPENAI_API_KEY=CHANGE_ME
ELEVENLABS_API_KEY=CHANGE_ME

# CORS — comma-separated list, no wildcards in production
CORS_ORIGINS=https://sonya-e.com,https://www.sonya-e.com

# Feature flags (safe defaults — enable per environment as needed)
SONYA_ENHANCERS_ENABLED=true
YOLO_COMMON_ENABLED=true
YOLO_POSE_ENABLED=true
WEBCAM_DETECTOR_ENABLED=true
GEMINI_DIRECT_VIDEO_ENABLED=false
GEMINI_LAYOUT_ENABLED=true
GEMINI_COMPOSER_ENABLED=true
SMART_CROP_ENABLED=true
WORD_LEVEL_SUBTITLES_ENABLED=true
LIP_SYNC_DETECTION_ENABLED=false
OPENAI_WHISPER_FALLBACK_ENABLED=false

# Upload limits
MAX_UPLOAD_SIZE_MB=2048

# Worker polling
WORKER_POLL_INTERVAL=10
WORKER_STALE_REQUEUE_INTERVAL=300

# Quota
QUOTA_ENABLED=true
QUOTA_MAX_CONCURRENT_JOBS=3
QUOTA_MAX_JOBS_PER_DAY=50

# Rate limiting
RATE_LIMIT_ENABLED=true

# Security audit
SECURITY_AUDIT_ENABLED=true

# Docs (disable in production)
ENABLE_DOCS=false
