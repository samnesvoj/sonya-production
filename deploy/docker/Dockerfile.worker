# Dockerfile.worker — SONYA production GPU worker image
#
# Build: docker build -f deploy/docker/Dockerfile.worker -t ghcr.io/samnesvoj/sonya-worker:latest .
#
# The repo is PRIVATE. This image ships the code so vast.ai instances
# never need to git-clone the repo. Secrets are NEVER baked in —
# they are injected at runtime via `docker run -e VAR=value`.
#
# Runtime requirements (injected via env, not baked in):
#   JOB_ID, MODE, BACKEND_API_URL, WORKER_SECRET
#   S3_ENDPOINT_URL, S3_ACCESS_KEY_ID, S3_SECRET_ACCESS_KEY,
#   S3_BUCKET_NAME, S3_REGION, MODELS_S3_BUCKET
#   OPENROUTER_API_KEY, GEMINI_API_KEY, ELEVENLABS_API_KEY, ELEVENLABS_VOICE_ID

FROM pytorch/pytorch:2.5.1-cuda12.4-cudnn9-runtime

# ── System packages ────────────────────────────────────────────────────────────
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update -qq \
 && apt-get install -y -qq --no-install-recommends \
      ffmpeg \
      git \
      curl \
      unzip \
      python3-venv \
      python3-pip \
 && apt-get clean \
 && rm -rf /var/lib/apt/lists/*

# ── Python deps ────────────────────────────────────────────────────────────────
WORKDIR /opt/sonya

# Copy only dependency manifests first for layer caching
COPY requirements-base.txt requirements-worker.txt ./

RUN pip install --no-cache-dir --upgrade pip \
 && pip install --no-cache-dir -r requirements-worker.txt

# ── Application code ───────────────────────────────────────────────────────────
# NOTE: .env, .env.local, models/, *.pt, *.onnx, *.safetensors are excluded
# by .dockerignore — never baked into the image.
COPY scripts/ ./scripts/
COPY modes/    ./modes/
COPY configs/  ./configs/
COPY README.md ./

# ── Runtime defaults ───────────────────────────────────────────────────────────
ENV APP_ENV=production \
    WORKER_BACKEND_MODE=api \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/opt/sonya

# ── Entrypoint ─────────────────────────────────────────────────────────────────
COPY deploy/docker/worker_entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
